generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  name            String
  role            String
  department      String?
  status          String   @default("ACTIVE")
  themePreference String   @default("system")
  permissions     String   @default("[]")
  avatar          String?
  phoneNumber     String?
  address         String?
  resumeUrl       String?
  authProvider    String   @default("local")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastLogin            DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  vendorId             String?
  referralCode         String?  @unique
  loginHistory         LoginHistory[]
}

model LoginHistory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loggedInAt DateTime @default(now())
  ipAddress  String?
  userAgent  String?

  @@index([userId, loggedInAt])
}

model Vendor {
  id          String   @id @default(cuid())
  name        String
  code        String?  @unique
  email       String
  phone       String?
  website     String?
  address     String?
  contactName String?
  status      String   @default("ACTIVE")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VendorRequirement {
  id            String   @id @default(cuid())
  vendorId      String
  requirementId String
  assignedAt    DateTime @default(now())
  assignedBy    String?

  @@unique([vendorId, requirementId])
}

model Requirement {
  id              String   @id @default(cuid())
  jobCode         String?  @unique
  client          String?
  title           String
  department      String
  hiringManager   String
  status          String
  hiringStage     String   @default("SOURCING")
  liveAt          DateTime?
  onHoldAt        DateTime?
  openings        Int
  filled          Int      @default(0)
  priority        String?
  location        String?
  locationCity      String?
  isRemote          Boolean  @default(false)
  workMode          String?
  employmentType    String?
  seniorityLevel    String?
  experienceMinYears Int?
  experienceMaxYears Int?
  salaryBand        String?
  targetStartDate   DateTime?
  hiringDeadline    DateTime?
  description     String?
  jobDescription  String?
  primarySkills   String   @default("[]")
  secondarySkills String   @default("[]")
  createdBy       String?
  createdByRole   String?
  recruiters      String   @default("[]")
  approval        String?
  approvalHistory String   @default("[]")
  versions        String   @default("[]")
  currentVersion        Int      @default(1)
  visibleToCandidates   Boolean  @default(true)
  visibleToVendors      Boolean  @default(false)
  visibleToReferrals    Boolean  @default(true)
  referralBonusAmount   Int?
  closureReason         String?
  closedAt              DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Candidate {
  id               String   @id @default(cuid())
  name             String
  email            String
  role             String
  status           String
  matchScore       Float    @default(0)
  source           String
  appliedDate      DateTime @default(now())
  requirementId    String?
  jobTitle         String?
  createdBy        String?
  avatar           String?
  resumeUrl        String?
  resumeFileName   String?
  resumeMimeType   String?
  phone            String?
  location         String?
  linkedIn         String?
  portfolio        String?
  totalExperience  String?
  currentCompany   String?
  currentCTC       String?
  expectedCTC      String?
  noticePeriod     String?
  pan              String?
  primarySkills    String   @default("[]")
  secondarySkills  String   @default("[]")
  resumeText       String?
  vendorId              String?
  submittedByUserId     String?
  referredByUserId      String?
  referralRelationship  String?
  referralNotes         String?
  offerDate              DateTime?
  offerMonth             String?
  offerQuarter           String?
  expectedJoiningDate    DateTime?
  joiningDate            DateTime?
  joiningMonth           String?
  joiningQuarter         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model InterviewPlan {
  id            String   @id @default(cuid())
  requirementId String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  stages        InterviewPlanStage[]
}

model InterviewPlanStage {
  id                    String   @id @default(cuid())
  planId                String
  order                 Int
  name                  String
  interviewType         String   @default("TECHNICAL")
  defaultDuration       Int      @default(60)
  defaultInterviewerIds String   @default("[]")
  plan                  InterviewPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  interviews            Interview[]

  @@unique([planId, order])
}

model Interview {
  id             String   @id @default(cuid())
  candidateId    String
  requirementId  String
  planStageId    String?
  scheduledAt    DateTime
  interviewerIds String   @default("[]")
  type           String
  status         String
  meetingLink    String?
  duration       Int?
  location       String?
  description    String?
  createdAt      DateTime @default(now())
  planStage      InterviewPlanStage? @relation(fields: [planStageId], references: [id], onDelete: SetNull)
}

model Feedback {
  id                  String   @id @default(cuid())
  interviewId         String
  interviewerId       String
  candidateId         String
  rating              Int
  technicalRating     Int?
  communicationRating Int?
  comments            String
  recommendation      String
  formData            String   @default("{}")
  createdAt           DateTime @default(now())
}

model Offer {
  id            String   @id @default(cuid())
  candidateId   String
  requirementId String
  baseSalary    Float
  equity        Float?
  bonus         Float?
  status        String
  history       String   @default("[]")
  letterContent String?
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SkillCatalog {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String   @default("General")
  createdAt DateTime @default(now())
}

model DepartmentCatalog {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model ClientCatalog {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model InterviewPanelLevel {
  id               String   @id @default(cuid())
  order            Int      @unique
  name             String
  interviewerIds   String   @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ActivityLog {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  action        String
  performedBy   String
  performerName String?
  performerRole String?
  details       String?
  timestamp     DateTime @default(now())
}

model RolePageAccess {
  role      String   @id
  pages     String
  updatedAt DateTime @updatedAt
}
