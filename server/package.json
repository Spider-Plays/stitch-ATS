{
  "name": "stitch-ats-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run db:generate && tsc",
    "start": "node dist/index.js",
    "start:deploy": "npm run db:push && npm start",
    "db:generate": "prisma generate",
    "db:push": "prisma db push && prisma generate",
    "db:seed": "tsx src/seed.ts",
    "db:seed-vendors": "tsx src/scripts/seed-vendors.ts",
    "db:seed-demo": "tsx src/scripts/seed-demo-data.ts --fresh",
    "db:clear": "tsx src/scripts/clear-db.ts",
    "db:bootstrap": "tsx src/scripts/bootstrap-admin.ts",
    "db:verify": "tsx src/scripts/verify-db.ts",
    "db:setup": "prisma db push && prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.5.0",
    "resend": "^6.12.3",
    "typescript": "^5.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.10",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.19.3"
  }
}
